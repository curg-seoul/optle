# Copy to .env. Optional for local dev (injected wallets like MetaMask work
# without it). Get a real project id at https://cloud.reown.com to enable
# WalletConnect (mobile wallets / QR) in the RainbowKit modal.
VITE_WALLETCONNECT_PROJECT_ID=

# Where `npm run dev` proxies /api + /health. Defaults to the deployed backend
# (https://api.optle.hanjun.kim), so local dev works without running the backend.
# Set to http://localhost:8080 to develop against a local server instead.
# DEV_API_TARGET=https://api.optle.hanjun.kim
