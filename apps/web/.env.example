# Copy to .env. Optional for local dev (injected wallets like MetaMask work
# without it). Get a real project id at https://cloud.reown.com to enable
# WalletConnect (mobile wallets / QR) in the RainbowKit modal.
VITE_WALLETCONNECT_PROJECT_ID=

# Production: the deployed backend URL the app calls directly (build-time var).
# Leave empty for local dev — the app uses relative /api paths that the dev server
# proxies (see DEV_API_TARGET).
VITE_API_BASE=

# Local dev only: where `npm run dev` proxies /api + /health. Defaults to a local
# backend; set to a deployed backend URL to develop against it instead.
# DEV_API_TARGET=http://localhost:8080

# Payment token used for the header balance readout (the deployed EIP-3009 USDC
# address). Leave empty to hide the balance. Decimals default to 6.
VITE_USDC_ADDRESS=
# VITE_USDC_DECIMALS=6
