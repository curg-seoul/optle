# Copy to .env and fill in. Placeholders are enough for the server to BOOT and
# return 402s locally; live verify/settle needs a funded testnet + facilitator key.

# --- server ---
PORT=8080
# enforce (default) = real x402 gate. bypass = skip payment for local UI demos
# (no facilitator needed). NEVER set bypass in production.
PAYMENT_MODE=enforce

# --- payment: Mantle Sepolia testnet (chainId 5003) ---
# Network identifier as the facilitator expects it. Once the facilitator enables
# Mantle for your key, confirm the exact string (e.g. "mantle-sepolia" or "eip155:5003").
PAYMENT_NETWORK=mantle-sepolia
PAYMENT_CHAIN_ID=5003

# Wallet that receives payments (real 0x address for live payments).
PAY_TO_ADDRESS=0x0000000000000000000000000000000000000000

# Chosen coin: USDC (EIP-3009 / gasless transferWithAuthorization — required by the
# x402 `exact` scheme). FILL the real Mantle Sepolia USDC address; it MUST implement
# EIP-3009. (No public EIP-3009 USDC address on Mantle Sepolia was confirmed at build
# time — obtain it from the facilitator's /supported list once Mantle is enabled, or
# from Mantle's testnet token registry; otherwise deploy a test EIP-3009 token.)
PAYMENT_ASSET_ADDRESS=0xUSDC_ON_MANTLE_SEPOLIA
PAYMENT_ASSET_NAME=USDC
PAYMENT_ASSET_DECIMALS=6
PAYMENT_EIP712_VERSION=2
# PAYMENT_PRICE is a fallback only; v2 charges per-job by project-size tier
# ($0.50 / $3 / $10 — see pricing.ts).
PAYMENT_PRICE=0.01

# --- storage: Tencent COS (stores each job's input.zip / output.zip) ---
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=          # e.g. optle-jobs-1250000000
COS_REGION=ap-singapore

# --- isolated runner (sibling Docker container per job) ---
# Set by docker-compose in production; defaults are fine elsewhere.
# RUNNER_IMAGE=optle-runner
# JOBS_DIR=/jobs           # this process's view of the per-job working dirs
# HOST_JOBS_DIR=/srv/optle-jobs  # SAME dir on the Docker host (for `docker run -v`)
# RUNNER_TIMEOUT_MS=600000
# RUNNER_MEMORY=2g
# RUNNER_CPUS=2

# --- facilitator (verifies + settles payments) ---
# Questflow is the multi-chain facilitator that announced Mantle support.
# NOTE: as of build time its public /supported listed only base / base-sepolia —
# Mantle may require an enabled API key. Apply at https://facilitator.questflow.ai
FACILITATOR_URL=https://facilitator.questflow.ai
FACILITATOR_API_KEY=

# --- optimization engine ---
# "auto" (default): use the real Claude agent when a key/token below is set,
# otherwise the offline mock optimizer. "mock": always use the mock (no AI cost) —
# set this on a public/demo site; leave auto for the real-AI run.
OPTLE_ENGINE=auto

# Verification: "on" (default) runs the full Foundry loop (snapshot → test →
# re-measure) for verified before/after gas. "off" = fast mode: apply
# optimizations only and skip forge test/fuzz — much faster (good for dev), but
# no verified gas numbers.
OPTLE_VERIFY=on

# --- AI engine (optional; without either of these the runner uses the mock pass) ---
# Option A: Anthropic API key (pay-as-you-go credits — needs a funded Console account).
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# Option B: Claude subscription token (no API credits). Generate with `claude setup-token`
# on a machine logged into your Pro/Max plan, then paste it here. If set, it takes
# precedence over ANTHROPIC_API_KEY. NOTE: subscription auth is meant for personal
# interactive use and has usage limits — fine for a demo, not for production serving.
CLAUDE_CODE_OAUTH_TOKEN=
# Optional model override (default: large tier → opus, else sonnet).
# CLAUDE_MODEL=claude-opus-4-8
