# Copy to .env and fill in. Placeholders are enough for the server to BOOT and
# return 402s locally.

# --- server ---
PORT=8080
# enforce (default) = real payment gate. bypass = skip payment for local UI demos.
# NEVER set bypass in production.
PAYMENT_MODE=enforce

# --- payment: native MNT on Mantle Sepolia testnet (chainId 5003) ---
PAYMENT_NETWORK=mantle-sepolia
PAYMENT_CHAIN_ID=5003
# RPC used to verify the payment tx on-chain (receipt + recipient + amount).
RPC_URL=https://rpc.sepolia.mantle.xyz

# Wallet that receives payments (native MNT).
PAY_TO_ADDRESS=0x0000000000000000000000000000000000000000

# Native token symbol shown in the UI / 402 challenge. Per-job price is by
# project-size tier in native MNT (0.01 / 0.05 / 0.2 — see pricing.ts).
PAYMENT_SYMBOL=MNT

# --- storage: Tencent COS (stores each job's input.zip / output.zip) ---
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=          # e.g. optle-jobs-1250000000
COS_REGION=ap-singapore

# --- isolated runner (sibling Docker container per job) ---
# Set by docker-compose in production; defaults are fine elsewhere.
# RUNNER_IMAGE=optle-runner
# JOBS_DIR=/jobs           # this process's view of the per-job working dirs
# HOST_JOBS_DIR=/srv/optle-jobs  # SAME dir on the Docker host (for `docker run -v`)
# RUNNER_TIMEOUT_MS=600000
# RUNNER_MEMORY=2g
# RUNNER_CPUS=2

# --- optimization engine ---
# "auto" (default): use the real Claude agent when a key/token below is set,
# otherwise the offline mock optimizer. "mock": always use the mock (no AI cost) —
# set this on a public/demo site; leave auto for the real-AI run.
OPTLE_ENGINE=auto

# Verification: "on" (default) runs the full Foundry loop (snapshot → test →
# re-measure) for verified before/after gas. "off" = fast mode: apply
# optimizations only and skip forge test/fuzz — much faster (good for dev), but
# no verified gas numbers.
OPTLE_VERIFY=on

# --- AI engine (optional; without either of these the runner uses the mock pass) ---
# Option A: Anthropic API key (pay-as-you-go credits — needs a funded Console account).
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# Option B: Claude subscription token (no API credits). Generate with `claude setup-token`
# on a machine logged into your Pro/Max plan, then paste it here. If set, it takes
# precedence over ANTHROPIC_API_KEY. NOTE: subscription auth is meant for personal
# interactive use and has usage limits — fine for a demo, not for production serving.
CLAUDE_CODE_OAUTH_TOKEN=
# Optional model override (default: large tier → opus, else sonnet).
# CLAUDE_MODEL=claude-opus-4-8
