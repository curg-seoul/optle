# Copy to .env and fill in. Placeholders below are enough for the server to BOOT
# and return 402s locally; real payment verification needs a funded testnet setup.

# --- server ---
PORT=8080

# --- x402 payment ---
# Wallet that receives payments (must be a real 0x address for live payments).
PAY_TO_ADDRESS=0x0000000000000000000000000000000000000000
# Price per optimization. "$0.01" = 0.01 USDC (x402 resolves the token per network).
PAYMENT_PRICE=$0.01
# ⚠️ x402 v1.2 does NOT support Mantle. Supported testnet default: base-sepolia.
#    For Mantle: custom-chain config + self-hosted facilitator (see PLAN §9 risk).
PAYMENT_NETWORK=base-sepolia
# Optional custom facilitator URL. Empty → x402's default testnet facilitator.
FACILITATOR_URL=

# --- AI (used only AFTER deploy; dev uses the mock optimizer, no API calls) ---
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
CLAUDE_MODEL=claude-opus-4-8
