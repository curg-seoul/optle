# Self-hosted x402 facilitator for Mantle Sepolia. Copy to .env and fill in.
# This stands in for a third-party facilitator (e.g. Questflow): it /verify's the
# client's signed EIP-3009 authorization and /settle's it on-chain, paying gas
# from RELAYER_PRIVATE_KEY.

PORT=8090

# Chain to settle on. Must match the server's PAYMENT_NETWORK / PAYMENT_CHAIN_ID
# and the chain the client signed for (browser wallet network).
CHAIN_ID=5003
NETWORK=mantle-sepolia
RPC_URL=https://rpc.sepolia.mantle.xyz

# Relayer pays MNT gas for the settle tx. Needs a funded Mantle Sepolia balance.
# The hackathon deploy wallet works (it has MNT). NEVER use a mainnet key.
RELAYER_PRIVATE_KEY=0xYOUR_RELAYER_PRIVATE_KEY
